HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# ── Email / SMTP (Office 365 — @365.dnu.edu.ua) ────────────────────────────
# Required for contact-form and application-form notifications.
# Use any @365.dnu.edu.ua mailbox that has SMTP AUTH enabled in M365 admin.
#
# SMTP_USER / SMTP_FROM  — the mailbox that sends the email (e.g. info@365.dnu.edu.ua)
# SMTP_PASS              — the mailbox password (or app password if MFA is enabled)
# ADMIN_NOTIFY_EMAIL     — where incoming form submissions are delivered
#                          (overridden by the "email" field in the CMS Contact Info entry)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-address@365.dnu.edu.ua
SMTP_PASS=your-outlook-password
SMTP_FROM=your-address@365.dnu.edu.ua
ADMIN_NOTIFY_EMAIL=info@365.dnu.edu.ua
