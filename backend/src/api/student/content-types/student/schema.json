{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student",
    "description": "Enrolled students / listeners"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program"
    },
    "program_name": {
      "type": "string"
    },
    "enrolled": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "completed", "paused"],
      "default": "active"
    }
  }
}
