{
  "kind": "collectionType",
  "collectionName": "applications",
  "info": {
    "singularName": "application",
    "pluralName": "applications",
    "displayName": "Application",
    "description": "Program applications from users"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "full_name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "organization": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program"
    },
    "program_name": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "processing", "approved", "rejected"],
      "default": "new"
    }
  }
}
