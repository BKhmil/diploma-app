{
  "kind": "collectionType",
  "collectionName": "applications",
  "info": {
    "singularName": "application",
    "pluralName": "applications",
    "displayName": "Application",
    "description": "Program applications from users"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "full_name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string"
    },
    "organization": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program"
    },
    "program_name": {
      "type": "string"
    },
    "message": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "processing", "accepted", "rejected"],
      "default": "new"
    },
    "category": {
      "type": "enumeration",
      "enum": ["ПК", "Перепідг.", "НМТ", "Магістр", "Інше"],
      "default": "Інше"
    },
    "manager_comment": {
      "type": "text"
    },
    "app_type": {
      "type": "enumeration",
      "enum": ["application", "contact"],
      "default": "application"
    },
    "financing": {
      "type": "enumeration",
      "enum": ["Контракт", "Бюджет", "Роботодавець"],
      "default": "Контракт"
    },
    "num": {
      "type": "integer"
    },
    "birth_date": {
      "type": "string"
    },
    "education_level": {
      "type": "string"
    },
    "diploma_specialty": {
      "type": "string"
    }
  }
}
