{
  "kind": "collectionType",
  "collectionName": "enrollments",
  "info": {
    "singularName": "enrollment",
    "pluralName": "enrollments",
    "displayName": "Enrollment",
    "description": "A single enrollment of a student into a program"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student.student",
      "inversedBy": "enrollments"
    },
    "program": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program.program"
    },
    "application": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::application.application"
    },
    "enrolled_at": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "completed", "cancelled"],
      "default": "active"
    }
  }
}
