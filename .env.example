# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=diploma_db
POSTGRES_USER=strapi
POSTGRES_PASSWORD=your_secure_password

# ─── Strapi secrets (generate with: openssl rand -base64 32) ─────────────────
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your_salt
ADMIN_JWT_SECRET=your_admin_jwt_secret
JWT_SECRET=your_jwt_secret
TRANSFER_TOKEN_SALT=your_transfer_salt
ENCRYPTION_KEY=your_encryption_key

# ─── First-launch superadmin (Strapi admin panel) ─────────────────────────────
# Used only when no admin users exist yet (auto-provisioned on first boot).
# Use a @365.dnu.edu.ua address for production.
SUPERADMIN_EMAIL=admin@365.dnu.edu.ua
SUPERADMIN_PASSWORD=your_strong_admin_password
SUPERADMIN_FIRSTNAME=ЦНО
SUPERADMIN_LASTNAME=Admin

# ─── Seed control ─────────────────────────────────────────────────────────────
# SEED_ON_FIRST_RUN=false   # set to false to skip seeding entirely
# SEED_FORCE=true           # set to true to force re-seed on next boot

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Leave VITE_STRAPI_URL empty for server deploy (nginx proxies /api → backend).
# Set to http://localhost:1337 only for local dev WITHOUT Docker networking.
VITE_STRAPI_URL=
VITE_STRAPI_LOCALE=uk

# ─── CORS (backend) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. With nginx same-origin proxy you
# typically don't need this, but set it if the frontend runs on a separate host.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Email / SMTP (Office 365 — @365.dnu.edu.ua) ─────────────────────────────
# Fill in to enable email notifications from contact & application forms.
# The backend sends an admin notification to ADMIN_NOTIFY_EMAIL on every form
# submission. Leave SMTP_USER / SMTP_PASS empty to disable email silently.
#
# Office 365: host=smtp.office365.com, port=587, secure=false, requireTLS=true
# Gmail app-password: host=smtp.gmail.com, port=587
# Mailtrap (testing): host=sandbox.smtp.mailtrap.io, port=2525
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_NOTIFY_EMAIL=info@365.dnu.edu.ua
