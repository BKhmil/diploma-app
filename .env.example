# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=diploma_db
POSTGRES_USER=strapi
POSTGRES_PASSWORD=your_secure_password

# Strapi
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your_salt
ADMIN_JWT_SECRET=your_admin_jwt_secret
JWT_SECRET=your_jwt_secret
TRANSFER_TOKEN_SALT=your_transfer_salt
ENCRYPTION_KEY=your_encryption_key

# Frontend
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
VITE_STRAPI_LOCALE=uk

# Email / SMTP (Office 365 — @365.dnu.edu.ua)
# Fill these in to enable email notifications from contact & application forms.
# The backend sends an admin notification to ADMIN_NOTIFY_EMAIL every time a
# form is submitted. Leave SMTP_USER / SMTP_PASS empty to disable email silently.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-address@365.dnu.edu.ua
SMTP_PASS=your-outlook-password
SMTP_FROM=your-address@365.dnu.edu.ua
ADMIN_NOTIFY_EMAIL=info@365.dnu.edu.ua
